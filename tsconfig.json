{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@workerbase/backend/*": ["backend/src/*"],
      "@workerbase/dashboard/*": ["dashboard/src/*"]
    }
  },
  "files": [],
  "references": [
    { "path": "./backend" },
    { "path": "./dashboard" }
  ]
}

{
  "name": "workerbase",
  "version": "0.0.0",
  "private": true,
  "description": "WorkerBase — Cloudflare-native dynamic backend + dashboard monorepo.",
  "workspaces": [
    "backend",
    "dashboard"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace backend",
    "dev:dashboard": "npm run dev --workspace dashboard",
    "dev": "concurrently -n backend,dashboard -c blue,magenta \"npm:dev:backend\" \"npm:dev:dashboard\"",
    "build:dashboard": "npm run build --workspace dashboard",
    "build:backend": "npm run build --workspace backend",
    "build": "npm run build:dashboard && npm run build:backend",
    "deploy": "npm run build:dashboard && npm run deploy --workspace backend",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
